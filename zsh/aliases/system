alias grep='rg'
alias l='ls -a'
alias e='yazi'

rpull() { rclone sync "$1" "$2" --filter-from ~/.config/rclone/filters.txt --progress; }
rpush() { rclone copy "$1" "$2" --filter-from ~/.config/rclone/filters.txt --progress; }
rcheck() { rclone check "$1" "$2" --filter-from ~/.config/rclone/filters.txt; }

{
	"$schema": "https://opencode.ai/config.json",
	"small_model": "ollama-cloud/deepseek-v4-flash",
	"instructions": ["SYSTEM.md"],
	"default_agent": "plan",
	"agent": {
		"plan": {
			"model": "ollama-cloud/glm-5.2",
			"color": "#c79eff"
		},
		"build": {
			"model": "ollama-cloud/glm-5.2",
			"color": "#98E4A7"
		},
		"explore": {
			"permission": {
				"*": "allow"
			}
		}
	},
	"mcp": {
		"deepwiki": {
			"enabled": true,
			"type": "remote",
			"url": "https://mcp.deepwiki.com/mcp"
		},
		"exa": {
			"enabled": true,
			"type": "remote",
			"url": "https://mcp.exa.ai/mcp"
		}
	},
	"permission": {
		"*": "ask",
		"read": "allow",
		"external_directory": "allow",
		"glob": "allow",
		"grep": "allow",
		"todowrite": "allow",
		"todoread": "allow",
		"webfetch": "allow",
		"websearch": "allow",
		"task": "allow",
		"deepwiki_*": "allow",
		"exa_*": "allow",
		"Exa*": "allow",
		"bash": {
			"pwd *": "allow",
			"ls *": "allow",
			"which *": "allow",
			"file *": "allow",
			"cat *": "allow",
			"head *": "allow",
			"tail *": "allow",
			"grep *": "allow",
			"rg *": "allow",
			"find *": "allow",
			"sort *": "allow",
			"echo *": "allow",
			"brew list *": "allow",
			"git status *": "allow",
			"git diff *": "allow",
			"git show *": "allow",
			"git log *": "allow"
		}
	},
	"experimental": {
		"disable_paste_summary": true
	}
}

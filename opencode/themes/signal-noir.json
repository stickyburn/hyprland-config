    "syntaxKeyword": { "dark": "pink", "light": "deep" },
    "syntaxFunction": { "dark": "cool", "light": "surface" },
    "syntaxVariable": { "dark": "text", "light": "canvas" },
    "syntaxString": { "dark": "mint", "light": "deep" },

{
  // UI
  "window.zoomLevel": 0,
  "editor.fontFamily": "Zed Sans",
  "terminal.integrated.fontFamily": "Zed Mono",
  "editor.fontSize": 13,
  "terminal.integrated.fontSize": 13,
  "editor.fontLigatures": true,
  "editor.cursorBlinking": "solid",
  "editor.cursorStyle": "line-thin",
  "editor.inlineSuggest.enabled": true,
  "editor.lineNumbers": "off",
  "editor.tabSize": 2,
  "editor.folding": false,
  "editor.foldingHighlight": false,
  "editor.glyphMargin": false,
  "editor.guides.indentation": false,
  "editor.inlayHints.enabled": "offUnlessPressed",
  "editor.minimap.enabled": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.decorations.colors": false,
  // terminal
  "terminal.integrated.cursorStyle": "underline",
  "terminal.integrated.scrollback": 10000,
  // search
  "search.exclude": {
    "**-lock.yaml": true,
    "**/*.cjs": true,
    "**/*.svg": true,
    "**/.cache": true,
    "**/.next": true,
    "**/@remote-types": true,
    "**/cache": true,
    "**/commit-msg": true,
    "**/dependabot.yml": true,
    "**/dist": true,
    "**/node_modules": true,
    "**/static": true,
    ".yarnrc.yml": true,
    "yarn.lock": true
  },
  // git
  "git.decorations.enabled": false,
  // workspace
  "breadcrumbs.enabled": false,
  "extensions.ignoreRecommendations": true,
  "json.schemaDownload.enable": true,
  "npm.packageManager": "auto",
  "window.commandCenter": true,
  "workbench.activityBar.location": "top",
  "workbench.colorTheme": "Visual Studio Dark",
  "workbench.editor.decorations.badges": false,
  "workbench.editor.decorations.colors": false,
  "workbench.sideBar.location": "right",
  "workbench.startupEditor": "none",
  "diffEditor.ignoreTrimWhitespace": true,
  "diffEditor.renderSideBySide": false,
  "diffEditor.useInlineViewWhenSpaceIsLimited": false,
  // LSP & formatting
  "editor.acceptSuggestionOnEnter": "smart",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always"
  },
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.quickSuggestions": {
    "strings": "on"
  },
  "js/ts.validate.enabled": false,
  // "[javascript]": {
  //   "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  // },
  // "[javascriptreact]": {
  //   "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  // },
  // "[typescript]": {
  //   "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  // },
  // "[typescriptreact]": {
  //   "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  // },
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer"
  },
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml"
  },
  // themes
  "window.autoDetectColorScheme": true,
  "workbench.preferredLightColorTheme": "Quiet Light",
  "workbench.preferredDarkColorTheme": "Visual Studio Dark",
  "workbench.colorCustomizations": {
    "[Quiet Light]": {
      "editor.background": "#eee9ff",
      "foreground": "#0e0f10",
      "descriptionForeground": "#2a1d31",
      "focusBorder": "#c79eff",
      "activityBar.background": "#eee9ff",
      "activityBar.foreground": "#0e0f10",
      "activityBar.inactiveForeground": "#2a1d31",
      "editor.foreground": "#0e0f10",
      "editor.lineHighlightBackground": "#ffeef2",
      "editor.selectionBackground": "#dffff8",
      "editorCursor.foreground": "#ff338f",
      "editorGroupHeader.tabsBackground": "#eee9ff",
      "editorGroupHeader.noTabsBackground": "#eee9ff",
      "editorGroup.emptyBackground": "#eee9ff",
      "editorOverviewRuler.border": "#ffeef2",
      "editorSuggestWidget.background": "#ffeef2",
      "editorSuggestWidget.border": "#c79eff",
      "editorSuggestWidget.selectedBackground": "#dffff8",
      "editorSuggestWidget.selectedForeground": "#0e0f10",
      "editorHoverWidget.background": "#ffeef2",
      "editorHoverWidget.border": "#c79eff",
      "input.background": "#ffeef2",
      "input.border": "#c79eff",
      "menu.background": "#ffeef2",
      "menu.selectionBackground": "#dffff8",
      "quickInput.background": "#ffeef2",
      "quickInputList.focusBackground": "#dffff8",
      "sideBar.background": "#eee9ff",
      "sideBar.foreground": "#0e0f10",
      "sideBarSectionHeader.background": "#eee9ff",
      "statusBar.background": "#eee9ff",
      "statusBar.foreground": "#0e0f10",
      "tab.activeBackground": "#eee9ff",
      "tab.activeBorderTop": "#ff338f",
      "tab.activeForeground": "#0e0f10",
      "tab.border": "#ffeef2",
      "tab.inactiveBackground": "#eee9ff",
      "tab.inactiveForeground": "#2a1d31",
      "titleBar.activeBackground": "#eee9ff",
      "titleBar.activeForeground": "#0e0f10",
      "panel.background": "#eee9ff",
      "panelSectionHeader.background": "#eee9ff",
      "panel.border": "#c79eff",
      "panelTitle.activeBorder": "#c79eff",
      "scrollbar.shadow": "#c79eff",
      "scrollbarSlider.background": "#c79eff",
      "scrollbarSlider.hoverBackground": "#ff91c3",
      "scrollbarSlider.activeBackground": "#ff91c3",
      "terminal.background": "#eee9ff",
      "terminal.foreground": "#0e0f10",
      "terminal.ansiBlack": "#0e0f10",
      "terminal.ansiRed": "#ff338f",
      "terminal.ansiGreen": "#221727",
      "terminal.ansiYellow": "#2a1d31",
      "terminal.ansiBlue": "#201a2f",
      "terminal.ansiMagenta": "#221727",
      "terminal.ansiCyan": "#2a1d31",
      "terminal.ansiWhite": "#eee9ff",
      "terminal.ansiBrightBlack": "#2a1d31",
      "terminal.ansiBrightRed": "#ff338f",
      "terminal.ansiBrightGreen": "#221727",
      "terminal.ansiBrightYellow": "#201a2f",
      "terminal.ansiBrightBlue": "#2a1d31",
      "terminal.ansiBrightMagenta": "#221727",
      "terminal.ansiBrightCyan": "#0e0f10",
      "terminal.ansiBrightWhite": "#ffeef2"
    },
    "[Visual Studio Dark]": {
      "editor.background": "#0e0f10",
      "foreground": "#eee9ff",
      "descriptionForeground": "#ff91c3",
      "focusBorder": "#c79eff",
      "activityBar.background": "#0e0f10",
      "activityBar.foreground": "#eee9ff",
      "activityBar.inactiveForeground": "#c79eff",
      "editor.foreground": "#eee9ff",
      "editor.lineHighlightBackground": "#0f0f1a",
      "editor.selectionBackground": "#2a1d31",
      "editorCursor.foreground": "#ff338f",
      "statusBar.foreground": "#eee9ff",
      "editorGroupHeader.tabsBackground": "#0e0f10",
      "editorGroupHeader.noTabsBackground": "#0e0f10",
      "editorGroup.emptyBackground": "#0e0f10",
      "editorOverviewRuler.border": "#0f0f1a",
      "editorSuggestWidget.background": "#121124",
      "editorSuggestWidget.border": "#2a1d31",
      "editorSuggestWidget.selectedBackground": "#2a1d31",
      "editorSuggestWidget.selectedForeground": "#eee9ff",
      "editorHoverWidget.background": "#121124",
      "editorHoverWidget.border": "#2a1d31",
      "input.background": "#121124",
      "input.border": "#2a1d31",
      "menu.background": "#121124",
      "menu.selectionBackground": "#2a1d31",
      "quickInput.background": "#121124",
      "quickInputList.focusBackground": "#2a1d31",
      "sideBar.background": "#0e0f10",
      "sideBar.foreground": "#eee9ff",
      "sideBarSectionHeader.background": "#0e0f10",
      "statusBar.background": "#0e0f10",
      "tab.activeBackground": "#0e0f10",
      "tab.activeBorderTop": "#ff338f",
      "tab.activeForeground": "#eee9ff",
      "tab.border": "#0f0f1a",
      "tab.inactiveBackground": "#0e0f10",
      "tab.inactiveForeground": "#ff91c3",
      "titleBar.activeBackground": "#0e0f10",
      "titleBar.activeForeground": "#eee9ff",
      "panel.background": "#0e0f10",
      "panelSectionHeader.background": "#0e0f10",
      "panel.border": "#2a1d31",
      "panelTitle.activeBorder": "#c79eff",
      "scrollbar.shadow": "#0e0f10",
      "scrollbarSlider.background": "#2a1d31",
      "scrollbarSlider.hoverBackground": "#c79eff",
      "scrollbarSlider.activeBackground": "#c79eff",
      "terminal.background": "#0e0f10",
      "terminal.foreground": "#eee9ff",
      "terminal.ansiBlack": "#0e0f10",
      "terminal.ansiRed": "#ff338f",
      "terminal.ansiGreen": "#98e4a7",
      "terminal.ansiYellow": "#ff91c3",
      "terminal.ansiBlue": "#c79eff",
      "terminal.ansiMagenta": "#ff91c3",
      "terminal.ansiCyan": "#dffff8",
      "terminal.ansiWhite": "#eee9ff",
      "terminal.ansiBrightBlack": "#2a1d31",
      "terminal.ansiBrightRed": "#ff338f",
      "terminal.ansiBrightGreen": "#98e4a7",
      "terminal.ansiBrightYellow": "#ffeef2",
      "terminal.ansiBrightBlue": "#c79eff",
      "terminal.ansiBrightMagenta": "#ff91c3",
      "terminal.ansiBrightCyan": "#dffff8",
      "terminal.ansiBrightWhite": "#ffeef2"
    }
  },
  "editor.tokenColorCustomizations": {
    "[Visual Studio Dark]": {
      "comments": "#c79eff",
      "strings": "#98e4a7",
      "numbers": "#ff338f",
      "keywords": "#ff91c3",
      "functions": "#dffff8",
      "types": "#dffff8",
      "variables": "#eee9ff",
      "textMateRules": [
        {
          "scope": [
            "comment",
            "punctuation.definition.comment"
          ],
          "settings": {
            "fontStyle": "italic",
            "foreground": "#c79eff"
          }
        },
        {
          "scope": [
            "keyword",
            "storage.type",
            "storage.modifier"
          ],
          "settings": {
            "fontStyle": "italic",
            "foreground": "#ff91c3"
          }
        },
        {
          "scope": [
            "punctuation",
            "keyword.operator"
          ],
          "settings": {
            "foreground": "#c79eff"
          }
        }
      ]
    },
    "[Quiet Light]": {
      "comments": "#2a1d31",
      "strings": "#221727",
      "numbers": "#ff338f",
      "keywords": "#221727",
      "functions": "#201a2f",
      "types": "#201a2f",
      "variables": "#0e0f10",
      "textMateRules": [
        {
          "scope": [
            "comment",
            "punctuation.definition.comment"
          ],
          "settings": {
            "fontStyle": "italic",
            "foreground": "#2a1d31"
          }
        },
        {
          "scope": [
            "keyword",
            "storage.type",
            "storage.modifier"
          ],
          "settings": {
            "fontStyle": "italic bold",
            "foreground": "#221727"
          }
        },
        {
          "scope": [
            "punctuation",
            "keyword.operator"
          ],
          "settings": {
            "foreground": "#2a1d31"
          }
        }
      ]
    }
  },
  "editor.semanticTokenColorCustomizations": {
    "[Visual Studio Dark]": {
      "enabled": true,
      "rules": {
        "*": "#eee9ff",
        "comment": {
          "foreground": "#c79eff",
          "italic": true
        },
        "string": "#98e4a7",
        "number": "#ff338f",
        "keyword": {
          "foreground": "#ff91c3",
          "italic": true
        },
        "function": "#dffff8",
        "method": "#dffff8",
        "type": "#dffff8",
        "class": "#dffff8",
        "operator": "#c79eff"
      }
    },
    "[Quiet Light]": {
      "enabled": true,
      "rules": {
        "*": "#0e0f10",
        "comment": {
          "foreground": "#2a1d31",
          "italic": true
        },
        "string": "#221727",
        "number": "#ff338f",
        "keyword": {
          "foreground": "#221727",
          "bold": true
        },
        "function": "#201a2f",
        "method": "#201a2f",
        "type": "#201a2f",
        "class": "#201a2f",
        "operator": "#2a1d31"
      }
    }
  },
  // remote dev
  "remote.SSH.remotePlatform": {
    "refyne": "linux",
    "runpod": "linux"
  }
}

{
  // UI
  "window.zoomLevel": 0,
  "editor.fontFamily": "Zed Sans",
  "terminal.integrated.fontFamily": "Zed Mono",
  "editor.fontSize": 12,
  "terminal.integrated.fontSize": 12,
  "editor.fontLigatures": true,
  "editor.cursorBlinking": "solid",
  "editor.cursorStyle": "line-thin",
  "editor.inlineSuggest.enabled": true,
  "editor.lineNumbers": "off",
  "editor.tabSize": 2,
  "editor.folding": false,
  "editor.foldingHighlight": false,
  "editor.glyphMargin": false,
  "editor.guides.indentation": false,
  "editor.inlayHints.enabled": "offUnlessPressed",
  "editor.minimap.enabled": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.decorations.colors": false,
  // terminal
  "terminal.integrated.cursorStyle": "underline",
  "terminal.integrated.scrollback": 10000,
  // search
  "search.exclude": {
    "**-lock.yaml": true,
    "**/*.cjs": true,
    "**/*.svg": true,
    "**/.cache": true,
    "**/.next": true,
    "**/@remote-types": true,
    "**/cache": true,
    "**/commit-msg": true,
    "**/dependabot.yml": true,
    "**/dist": true,
    "**/node_modules": true,
    "**/static": true,
    ".yarnrc.yml": true,
    "yarn.lock": true
  },
  // git
  "git.decorations.enabled": false,
  // workspace
  "breadcrumbs.enabled": false,
  "extensions.ignoreRecommendations": true,
  "json.schemaDownload.enable": true,
  "npm.packageManager": "auto",
  "window.commandCenter": true,
  "workbench.activityBar.location": "top",
  "workbench.colorTheme": "Light Modern",
  "workbench.editor.decorations.badges": false,
  "workbench.editor.decorations.colors": false,
  "workbench.sideBar.location": "right",
  "workbench.startupEditor": "none",
  "diffEditor.ignoreTrimWhitespace": true,
  "diffEditor.renderSideBySide": true,
  "diffEditor.useInlineViewWhenSpaceIsLimited": false,
  // LSP & formatting
  "editor.acceptSuggestionOnEnter": "smart",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always"
  },
  "editor.formatOnPaste": true,
  "editor.formatOnSave": true,
  "editor.quickSuggestions": {
    "strings": "on"
  },
  "js/ts.validate.enabled": false,
  "[javascript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[typescript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[html]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  "svelte.ask-to-enable-ts-plugin": false,
  // themes
  "window.autoDetectColorScheme": true,
  "workbench.preferredLightColorTheme": "Quiet Light",
  "workbench.preferredDarkColorTheme": "Visual Studio Dark",
  "workbench.colorCustomizations": {
    "[Quiet Light]": {
      "editor.background": "#eee9ff",
      "activityBar.background": "#eee9ff",
      "editor.foreground": "#0f0f1a",
      "statusBar.foreground": "#0f0f1a",
      "editorGroupHeader.tabsBackground": "#eee9ff",
      "editorOverviewRuler.border": "#eee9ff",
      "editorSuggestWidget.background": "#eee9ff",
      "editorSuggestWidget.border": "#eee9ff",
      "editorSuggestWidget.selectedBackground": "#eee9ff",
      "input.background": "#eee9ff",
      "menu.background": "#eee9ff",
      "quickInput.background": "#eee9ff",
      "sideBar.background": "#eee9ff",
      "statusBar.background": "#eee9ff",
      "tab.activeBackground": "#eee9ff",
      "tab.activeBorderTop": "#eee9ff",
      "tab.border": "#eee9ff",
      "tab.inactiveBackground": "#eee9ff",
      "titleBar.activeBackground": "#eee9ff",
      "panel.background": "#eee9ff",
      "scrollbar.shadow": "#dbd2fb",
      "scrollbarSlider.activeBackground": "#dbd2fb",
      "scrollbarSlider.background": "#dbd2fb",
      "scrollbarSlider.hoverBackground": "#dbd2fb",
      "tab.activeBorder": "#dbd2fb",
      "editor.lineHighlightBackground": "#dbd2fb",
      "editor.selectionBackground": "#dbd2fb",
      "editorHoverWidget.background": "#dbd2fb",
      "quickInputList.focusBackground": "#dbd2fb",
      "panel.border": "#c79eff",
      "panelTitle.activeBorder": "#c79eff",
      "editorSuggestWidget.selectedForeground": "#6A6367",
      "tab.inactiveForeground": "#6A6367"
    },
    "[Visual Studio Dark]": {
      "editor.background": "#0f0f1a",
      "activityBar.background": "#0f0f1a",
      "editor.foreground": "#eee9ff",
      "statusBar.foreground": "#eee9ff",
      "editorGroupHeader.tabsBackground": "#0f0f1a",
      "editorOverviewRuler.border": "#0f0f1a",
      "editorSuggestWidget.background": "#0f0f1a",
      "editorSuggestWidget.border": "#0f0f1a",
      "editorSuggestWidget.selectedBackground": "#0f0f1a",
      "input.background": "#0f0f1a",
      "menu.background": "#0f0f1a",
      "quickInput.background": "#0f0f1a",
      "sideBar.background": "#0f0f1a",
      "statusBar.background": "#0f0f1a",
      "tab.activeBackground": "#0f0f1a",
      "tab.activeBorderTop": "#0f0f1a",
      "tab.border": "#0f0f1a",
      "tab.inactiveBackground": "#0f0f1a",
      "titleBar.activeBackground": "#0f0f1a",
      "terminal.background": "#0f0f1a",
      "tab.activeBorder": "#292947",
      "scrollbar.shadow": "#292947",
      "scrollbarSlider.activeBackground": "#292947",
      "scrollbarSlider.background": "#292947",
      "scrollbarSlider.hoverBackground": "#292947",
      "editor.lineHighlightBackground": "#292947",
      "editor.selectionBackground": "#292947",
      "editorHoverWidget.background": "#292947",
      "quickInputList.focusBackground": "#292947",
      "panel.border": "#c79eff",
      "panelTitle.activeBorder": "#c79eff",
      "editorSuggestWidget.selectedForeground": "#6A6367",
      "tab.inactiveForeground": "#6A6367",
    }
  },
  // remote dev
  "remote.SSH.remotePlatform": {
    "refyne": "linux",
    "runpod": "linux"
  }
}